# Database
DB_PASSWORD=changeme

# JWT signing secret (generate a 256-bit secret: openssl rand -base64 32)
JWT_SECRET=changeme-generate-a-256-bit-secret

# Application origin (used by SvelteKit for CSRF protection)
APP_ORIGIN=https://prosperity.example.com

# Application domain (used by Caddy for TLS)
APP_DOMAIN=prosperity.example.com
