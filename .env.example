# .env.example — copy to `.env` for local PowerSync dev (compose.dev.yml).
#
# DEV ONLY — NEVER copy these values to production. Production credentials must
# come from a secrets manager (E16). NOTE: unlike DATABASE_URL / JWT_SECRET,
# these PS_* values are NOT covered by backend.config's
# `_forbid_dev_defaults_in_prod` guard (they live outside Pydantic), so nothing
# stops a prod deploy from reusing them. See runbooks/powersync_setup.md §Sécurité.

# Pinned PowerSync Service image tag — never `latest`. Bump deliberately.
PS_IMAGE_TAG=1.22.0

# Port the PowerSync API server listens on (and is published on the host).
PS_PORT=8080

# Source DB connection for the replication worker. The `powersync` role is a
# least-privilege LOGIN REPLICATION role created by
# compose/initdb/00_powersync_roles.sql. The password below MUST match the one
# in that script. DEV ONLY — a known dev password, NEVER reuse in production.
PS_SOURCE_URI=postgresql://powersync:powersync_dev@postgres:5432/prosperity

# Bucket-storage DB connection (separate database, same dev instance). The
# `ps_storage` role owns `powersync_storage` (PowerSync creates its own schema
# there, so it needs ownership/CREATE). Password MUST match 00_powersync_roles.sql.
# DEV ONLY — NEVER reuse in production.
PS_STORAGE_URI=postgresql://ps_storage:ps_storage_dev@postgres:5432/powersync_storage

# JWKS endpoint used to validate client JWTs. Dev placeholder only — the real
# JWKS is served by the backend and wired in S13.8/E14 (ADR 0016). `client_auth`
# in config.yaml sets `allow_local_jwks: true` so a local http URL is accepted.
PS_JWKS_URI=http://localhost:8080/dev-jwks.json

# Token for the PowerSync local admin API routes (diagnostics). DEV ONLY.
PS_ADMIN_TOKEN=dev_admin_token_change_in_prod

# Log level for the PowerSync Service. Keep `info` in prod — `debug` logs
# replication payloads (see runbooks/powersync_setup.md §Sécurité).
PS_LOG_LEVEL=info
