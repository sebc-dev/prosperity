    backend.modules.mcp.repository
    backend.modules.mcp.transports
    backend.modules.mcp.handlers
    backend.modules.notifications.service
    backend.modules.notifications.models
    backend.modules.notifications.domain
    backend.modules.notifications.repository
    backend.modules.notifications.transports
    backend.modules.notifications.handlers
    backend.modules.reconciliation.service
    backend.modules.reconciliation.models
    backend.modules.reconciliation.domain
    backend.modules.reconciliation.repository
    backend.modules.reconciliation.transports
    backend.modules.reconciliation.handlers
    backend.modules.savings.service
    backend.modules.savings.models
    backend.modules.savings.domain
    backend.modules.savings.repository
    backend.modules.savings.transports
    backend.modules.savings.handlers
    backend.modules.sync.service
    backend.modules.sync.models
    backend.modules.sync.domain
    backend.modules.sync.repository
    backend.modules.sync.transports
    backend.modules.sync.handlers
    backend.modules.transactions.service
    backend.modules.transactions.models
    backend.modules.transactions.domain
    backend.modules.transactions.repository
    backend.modules.transactions.transports
    backend.modules.transactions.handlers
# Edges that constitute the legitimate `budget → auth.public` surface
# (S06.3 `/categories` routes): `budget.transports.http` imports `User` /
# `get_current_user` (P06.3.2) and `log_admin_action` / `AdminAction`
# (P06.3.3) from `auth.public`. `find_shortest_chains` would otherwise
# surface `budget → auth.public → auth.{domain, models, service.*,
# transports.dependencies}` as broken chains; ignoring the *second hop*
# (auth.public → auth.X) makes those chains invisible without weakening the
# direct-import protection (a hypothetical `budget.service.X → auth.models`
# would still be flagged). The nine `auth.public → auth.X` arcs are the same
# block as contract `2-accounts`. The four `accounts.public → accounts.X` arcs
# (S08.2, mirror of `2-transactions`) cover the consumption service:
# `budget.service.consumption` / `budget.service.budgets` import
# `owned_personal_account_ids` / `shared_account_ids_with_members_subset` from
# `accounts.public` (D7 contributor filter — `accounts` sits *below* budget in
# contract 1, so this is the legitimate arc; `transactions`, a peer, is read via
# SQLAlchemy Core instead, never imported). All thirteen arcs exist in the
# `.public` modules independently of budget, so each is "matched".
ignore_imports =
    backend.modules.auth.public -> backend.modules.auth.domain
    backend.modules.auth.public -> backend.modules.auth.models
    backend.modules.auth.public -> backend.modules.auth.service.audit
    backend.modules.auth.public -> backend.modules.auth.service.invitations
    backend.modules.auth.public -> backend.modules.auth.service.jwt
    backend.modules.auth.public -> backend.modules.auth.service.refresh_tokens
    backend.modules.auth.public -> backend.modules.auth.service.roles
    backend.modules.auth.public -> backend.modules.auth.service.users
    backend.modules.auth.public -> backend.modules.auth.transports.dependencies
    backend.modules.accounts.public -> backend.modules.accounts.models
    backend.modules.accounts.public -> backend.modules.accounts.service.accounts
    backend.modules.accounts.public -> backend.modules.accounts.service.household
    backend.modules.accounts.public -> backend.modules.accounts.service.setup
unmatched_ignore_imports_alerting = error

[importlinter:contract:2-transactions]
name = transactions must not import peer modules' internals
type = forbidden
# Transactions-as-source mirrors the `2-auth` / `2-accounts` / `2-budget`
# split: S07.2 gives transactions its first internals (`transactions.models`),
# so transactions can no longer sit in contract:2's `source_modules`
# (transactions and `backend.modules.*.models` would share a descendant →
# grimp's shared-descendants error). Intra-module imports
# (transactions.public → transactions.models) stay legitimate; peer modules'
# internals are enumerated explicitly so transactions' own never appear here.
# auth/accounts are below transactions in the layer graph, so transactions may
# import their `.public` freely — reaching into their internals stays
# forbidden. The `ignore_imports` block below was added in S07.5 when the routes
# (`transactions.transports.http`) first import `auth.public` (`get_current_user`)
# and `accounts.public` (`account_is_accessible` / `accessible_account_ids`):
# `find_shortest_chains` would otherwise surface
# `transactions → auth.public → auth.X` and `transactions → accounts.public →
# accounts.X` as broken chains. Ignoring the *second hop* (X.public → X.internal)
# makes those invisible without weakening the direct-import protection (a
# hypothetical `transactions.service.Y → auth.models` would still be flagged).
source_modules =
    backend.modules.transactions
forbidden_modules =
    backend.modules.auth.service
    backend.modules.auth.models
    backend.modules.auth.domain
    backend.modules.auth.repository
    backend.modules.auth.transports
    backend.modules.auth.handlers
    backend.modules.accounts.service
    backend.modules.accounts.models
    backend.modules.accounts.domain
    backend.modules.accounts.repository
    backend.modules.accounts.transports
    backend.modules.accounts.handlers
    backend.modules.banking.service
    backend.modules.banking.models
