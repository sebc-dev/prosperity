    backend.modules.mcp.repository
    backend.modules.mcp.transports
    backend.modules.mcp.handlers
    backend.modules.notifications.service
    backend.modules.notifications.models
    backend.modules.notifications.domain
    backend.modules.notifications.repository
    backend.modules.notifications.transports
    backend.modules.notifications.handlers
    backend.modules.reconciliation.service
    backend.modules.reconciliation.models
    backend.modules.reconciliation.domain
    backend.modules.reconciliation.repository
    backend.modules.reconciliation.transports
    backend.modules.reconciliation.handlers
    backend.modules.savings.service
    backend.modules.savings.models
    backend.modules.savings.domain
    backend.modules.savings.repository
    backend.modules.savings.transports
    backend.modules.savings.handlers
    backend.modules.sync.service
    backend.modules.sync.models
    backend.modules.sync.domain
    backend.modules.sync.repository
    backend.modules.sync.transports
    backend.modules.sync.handlers
    backend.modules.transactions.service
    backend.modules.transactions.models
    backend.modules.transactions.domain
    backend.modules.transactions.repository
    backend.modules.transactions.transports
    backend.modules.transactions.handlers
# Edges that constitute the legitimate `accounts → auth.public` surface
# (S03.2 `/setup` flow): re-exports defined inside `auth.public` are
# how accounts is allowed to consume auth. `find_shortest_chains`
# would otherwise surface `accounts → auth.public → auth.{models,
# service.*, transports.dependencies}` as broken chains; ignoring the
# *second hop* (auth.public → auth.X) makes those chains invisible
# without weakening the direct-import protection (a hypothetical
# `accounts.service.X → auth.models` would still be flagged).
ignore_imports =
    backend.modules.auth.public -> backend.modules.auth.domain
    backend.modules.auth.public -> backend.modules.auth.models
    backend.modules.auth.public -> backend.modules.auth.service.audit
    backend.modules.auth.public -> backend.modules.auth.service.invitations
    backend.modules.auth.public -> backend.modules.auth.service.jwt
    backend.modules.auth.public -> backend.modules.auth.service.refresh_tokens
    backend.modules.auth.public -> backend.modules.auth.service.roles
    backend.modules.auth.public -> backend.modules.auth.service.users
    backend.modules.auth.public -> backend.modules.auth.transports.dependencies
unmatched_ignore_imports_alerting = error

[importlinter:contract:2-budget]
name = budget must not import peer modules' internals
type = forbidden
# Budget-as-source mirrors the `2-auth` / `2-accounts` split: S06.1 gives
# budget its first internals (`budget.models`), so budget can no longer
# sit in contract:2's `source_modules` (budget and `backend.modules.*.models`
# would share a descendant → grimp's shared-descendants error). Intra-module
# imports (budget.public → budget.models) stay legitimate; peer modules'
# internals are enumerated explicitly so budget's own never appear here.
# auth/accounts are below budget in the layer graph, so budget may import
# their `.public` freely — reaching into their internals stays forbidden.
source_modules =
    backend.modules.budget
forbidden_modules =
    backend.modules.auth.service
    backend.modules.auth.models
    backend.modules.auth.domain
    backend.modules.auth.repository
    backend.modules.auth.transports
