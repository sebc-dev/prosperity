    backend.modules.mcp.domain
    backend.modules.mcp.repository
    backend.modules.mcp.transports
    backend.modules.mcp.handlers
    backend.modules.notifications.service
    backend.modules.notifications.models
    backend.modules.notifications.domain
    backend.modules.notifications.repository
    backend.modules.notifications.transports
    backend.modules.notifications.handlers
    backend.modules.reconciliation.service
    backend.modules.reconciliation.models
    backend.modules.reconciliation.domain
    backend.modules.reconciliation.repository
    backend.modules.reconciliation.transports
    backend.modules.reconciliation.handlers
    backend.modules.savings.service
    backend.modules.savings.models
    backend.modules.savings.domain
    backend.modules.savings.repository
    backend.modules.savings.transports
    backend.modules.savings.handlers
    backend.modules.sync.service
    backend.modules.sync.models
    backend.modules.sync.domain
    backend.modules.sync.repository
    backend.modules.sync.transports
    backend.modules.sync.handlers
# Legitimate `transactions → {auth,accounts}.public` surface (S07.5 routes):
# `transactions.transports.http` imports `User`/`get_current_user` from
# `auth.public` and `account_is_accessible`/`accessible_account_ids` from
# `accounts.public`. The nine `auth.public → auth.X` arcs are the same block as
# `2-accounts`/`2-budget`; the four `accounts.public → accounts.X` arcs cover the
# re-exports `accounts.public` makes (events import only `shared.events`, so
# `accounts.events` is not forbidden and stays out of this block). All thirteen
# arcs exist in the `.public` modules independently of transactions → each is
# "matched" (`unmatched_ignore_imports_alerting = error`).
ignore_imports =
    backend.modules.auth.public -> backend.modules.auth.domain
    backend.modules.auth.public -> backend.modules.auth.models
    backend.modules.auth.public -> backend.modules.auth.service.audit
    backend.modules.auth.public -> backend.modules.auth.service.invitations
    backend.modules.auth.public -> backend.modules.auth.service.jwt
    backend.modules.auth.public -> backend.modules.auth.service.refresh_tokens
    backend.modules.auth.public -> backend.modules.auth.service.roles
    backend.modules.auth.public -> backend.modules.auth.service.users
    backend.modules.auth.public -> backend.modules.auth.transports.dependencies
    backend.modules.accounts.public -> backend.modules.accounts.models
    backend.modules.accounts.public -> backend.modules.accounts.service.accounts
    backend.modules.accounts.public -> backend.modules.accounts.service.household
    backend.modules.accounts.public -> backend.modules.accounts.service.setup
unmatched_ignore_imports_alerting = error

[importlinter:contract:2-debts]
name = debts must not import peer modules' internals
type = forbidden
# Debts-as-source mirrors the `2-auth` / `2-accounts` / `2-budget` /
# `2-transactions` split: S09.1 gives debts its first internals
# (`debts.models`), so debts can no longer sit in contract:2's `source_modules`
# (debts and `backend.modules.*.models` would share a descendant → grimp's
# shared-descendants error). Intra-module imports (debts.public → debts.models)
# stay legitimate; peer modules' internals are enumerated explicitly so debts'
# own never appear here. auth/accounts/transactions are below debts in the layer
# graph (contract 1), so debts may import their `.public` freely — reaching into
# their internals stays forbidden. NO `ignore_imports` block yet: S09.1 adds no
# cross-module import (the `transactions.share_request_id` link is a DB-level FK
# declared by string, not a Python import). The second-hop blocks
# (`auth.public → auth.X`, etc.) arrive in S09.3 when debts first imports a
# `.public` surface — and will enumerate ONLY the arcs actually imported, since
# `unmatched_ignore_imports_alerting = error` would otherwise break the lint.
source_modules =
    backend.modules.debts
forbidden_modules =
    backend.modules.auth.service
    backend.modules.auth.models
    backend.modules.auth.domain
    backend.modules.auth.repository
    backend.modules.auth.transports
    backend.modules.auth.handlers
    backend.modules.accounts.service
    backend.modules.accounts.models
    backend.modules.accounts.domain
    backend.modules.accounts.repository
    backend.modules.accounts.transports
    backend.modules.accounts.handlers
    backend.modules.banking.service
    backend.modules.banking.models
    backend.modules.banking.domain
    backend.modules.banking.repository
    backend.modules.banking.transports
    backend.modules.banking.handlers
    backend.modules.budget.service
    backend.modules.budget.models
    backend.modules.budget.domain
    backend.modules.budget.repository
    backend.modules.budget.transports
    backend.modules.budget.handlers
    backend.modules.forecasting.service
    backend.modules.forecasting.models
    backend.modules.forecasting.domain
    backend.modules.forecasting.repository
    backend.modules.forecasting.transports
    backend.modules.forecasting.handlers
    backend.modules.mcp.service
    backend.modules.mcp.models
    backend.modules.mcp.domain
    backend.modules.mcp.repository
    backend.modules.mcp.transports
    backend.modules.mcp.handlers
    backend.modules.notifications.service
    backend.modules.notifications.models
    backend.modules.notifications.domain
    backend.modules.notifications.repository
    backend.modules.notifications.transports
    backend.modules.notifications.handlers
    backend.modules.reconciliation.service
    backend.modules.reconciliation.models
    backend.modules.reconciliation.domain
    backend.modules.reconciliation.repository
    backend.modules.reconciliation.transports
    backend.modules.reconciliation.handlers
    backend.modules.savings.service
    backend.modules.savings.models
    backend.modules.savings.domain
    backend.modules.savings.repository
    backend.modules.savings.transports
    backend.modules.savings.handlers
    backend.modules.sync.service
    backend.modules.sync.models
    backend.modules.sync.domain
    backend.modules.sync.repository
    backend.modules.sync.transports
    backend.modules.sync.handlers
    backend.modules.transactions.service
    backend.modules.transactions.models
    backend.modules.transactions.domain
    backend.modules.transactions.repository
    backend.modules.transactions.transports
    backend.modules.transactions.handlers
# Legitimate `debts → {auth,accounts,transactions}.public` surface (S09.3): the
# service (`debts.service.share_request`) imports `user_is_active_member` from
# `auth.public`, `account_is_accessible`/`owned_personal_account_ids` from
# `accounts.public`, and `get_transaction`/`TransactionState` from
# `transactions.public`; the routes (`debts.transports.http`) import
# `User`/`get_current_user` from `auth.public`. `find_shortest_chains` would
# otherwise surface `debts → X.public → X.internal` as broken chains. Ignoring
# the *second hop* (X.public → X.internal) makes those invisible without
# weakening the direct-import protection (a hypothetical `debts.service.Y →
# auth.models` would still be flagged). The nine `auth.public → auth.X` arcs are
# the same block as `2-accounts`/`2-budget`/`2-transactions`; the four
# `accounts.public → accounts.X` arcs cover its re-exports (`accounts.events`
# imports only `shared.events`, so it is not forbidden and stays out). The three
# `transactions.public → transactions.X` arcs cover `domain` (`TransactionState`
# AND `is_transfer`, the latter consumed by `debts.service.settlement` since S10.4),
# `service.queries` (`get_transaction`), AND `service.lifecycle`: the service
# consumes only the `domain` and `service.queries` symbols, but `find_shortest_chains` routes `debts →
# transactions.public → transactions.service.lifecycle` as soon as `debts` imports
# `transactions.public` as a module (independent of the symbols consumed) — DO NOT
# drop the `lifecycle` arc believing it unused, it would break the lint.
# `transactions.events` imports only `shared.events`, so it is not forbidden and
# stays out (mirror of `accounts.events` in `2-transactions`). The S11.3 overflow
# materializer (`debts.service.overflow_materializer`) adds the FIRST `debts →
# budget.public` arc (`resolve_overflow_context`/`OverflowBudgetContext` live in
# `budget.service.consumption`): `debts` is *above* `budget` in contract 1, so the
# arc is directionally legitimate. The four `budget.public → budget.X` second-hops
# below cover it — `budget.public` re-exports from `domain`, `service.budgets`,
# `service.consumption` and `service.threshold_detector` (`budget.events` imports
# only `shared.events`, so it is not forbidden and stays out). All twenty arcs
# exist in the `.public` modules independently of debts → each is "matched"
# (`unmatched_ignore_imports_alerting = error`).
ignore_imports =
    backend.modules.auth.public -> backend.modules.auth.domain
    backend.modules.auth.public -> backend.modules.auth.models
    backend.modules.auth.public -> backend.modules.auth.service.audit
    backend.modules.auth.public -> backend.modules.auth.service.invitations
    backend.modules.auth.public -> backend.modules.auth.service.jwt
    backend.modules.auth.public -> backend.modules.auth.service.refresh_tokens
    backend.modules.auth.public -> backend.modules.auth.service.roles
    backend.modules.auth.public -> backend.modules.auth.service.users
    backend.modules.auth.public -> backend.modules.auth.transports.dependencies
    backend.modules.accounts.public -> backend.modules.accounts.models
    backend.modules.accounts.public -> backend.modules.accounts.service.accounts
    backend.modules.accounts.public -> backend.modules.accounts.service.household
    backend.modules.accounts.public -> backend.modules.accounts.service.setup
    backend.modules.transactions.public -> backend.modules.transactions.domain
    backend.modules.transactions.public -> backend.modules.transactions.service.lifecycle
    backend.modules.transactions.public -> backend.modules.transactions.service.queries
    backend.modules.budget.public -> backend.modules.budget.domain
    backend.modules.budget.public -> backend.modules.budget.service.budgets
    backend.modules.budget.public -> backend.modules.budget.service.consumption
    backend.modules.budget.public -> backend.modules.budget.service.threshold_detector
unmatched_ignore_imports_alerting = error

[importlinter:contract:2-banking]
name = banking must not import peer modules' internals
type = forbidden
# Banking-as-source mirrors the `2-auth` / `2-accounts` / `2-budget` /
# `2-transactions` / `2-debts` split: S12.1 gives banking its first internals
# (`banking.models`), so banking can no longer sit in contract:2's
# `source_modules` (banking and `backend.modules.*.models` would share a
# descendant → grimp's shared-descendants error). Intra-module imports
# (banking.public → banking.models / banking.service) stay legitimate; peer
# modules' internals are enumerated explicitly so banking's own never appear
# here. auth/accounts are below banking in the layer graph (contract 1), so
# banking may import their `.public` freely — reaching into their internals
# stays forbidden. NO `ignore_imports` block: banking still imports no peer
# `.public` surface. S12.4 (OFX import routes/commit) does NOT change this — the
# whole cross-module assembly (`banking.public` + `transactions.public`) lives at
# the composition root (`backend.transports`, contract 6), OUTSIDE `backend.modules`;
# banking only gains intra-module write/read primitives (`record_imported`,
# `known_import_hashes`). A second-hop block here will arrive only when banking
# itself first consumes a peer `.public` surface (not in S12.4).
source_modules =
    backend.modules.banking
forbidden_modules =
    backend.modules.auth.service
    backend.modules.auth.models
    backend.modules.auth.domain
    backend.modules.auth.repository
    backend.modules.auth.transports
    backend.modules.auth.handlers
    backend.modules.accounts.service
    backend.modules.accounts.models
    backend.modules.accounts.domain
    backend.modules.accounts.repository
    backend.modules.accounts.transports
    backend.modules.accounts.handlers
    backend.modules.budget.service
    backend.modules.budget.models
    backend.modules.budget.domain
    backend.modules.budget.repository
    backend.modules.budget.transports
    backend.modules.budget.handlers
    backend.modules.debts.service
    backend.modules.debts.models
    backend.modules.debts.domain
    backend.modules.debts.repository
    backend.modules.debts.transports
    backend.modules.debts.handlers
    backend.modules.forecasting.service
    backend.modules.forecasting.models
    backend.modules.forecasting.domain
    backend.modules.forecasting.repository
    backend.modules.forecasting.transports
    backend.modules.forecasting.handlers
    backend.modules.mcp.service
    backend.modules.mcp.models
    backend.modules.mcp.domain
    backend.modules.mcp.repository
    backend.modules.mcp.transports
    backend.modules.mcp.handlers
    backend.modules.notifications.service
    backend.modules.notifications.models
    backend.modules.notifications.domain
    backend.modules.notifications.repository
    backend.modules.notifications.transports
    backend.modules.notifications.handlers
    backend.modules.reconciliation.service
    backend.modules.reconciliation.models
    backend.modules.reconciliation.domain
    backend.modules.reconciliation.repository
    backend.modules.reconciliation.transports
    backend.modules.reconciliation.handlers
    backend.modules.savings.service
    backend.modules.savings.models
    backend.modules.savings.domain
    backend.modules.savings.repository
    backend.modules.savings.transports
    backend.modules.savings.handlers
    backend.modules.sync.service
    backend.modules.sync.models
    backend.modules.sync.domain
    backend.modules.sync.repository
    backend.modules.sync.transports
    backend.modules.sync.handlers
    backend.modules.transactions.service
    backend.modules.transactions.models
    backend.modules.transactions.domain
    backend.modules.transactions.repository
    backend.modules.transactions.transports
    backend.modules.transactions.handlers

[importlinter:contract:3]
name = shared imports nothing of modules
type = forbidden
source_modules =
    backend.shared
forbidden_modules =
    backend.modules.*

# Reader/provider split (ADR 0009): only banking.service.polling drives the
# external BankingProvider; the rest of the codebase consumes BankingReader via
# banking.public. banking.public itself re-exports the BankingProvider type
# (for typing in polling), which is also whitelisted.
[importlinter:contract:4]
name = BankingProvider used only by polling
type = forbidden
# `banking.providers` is internal to `banking`; ADR 0009 + F14 require that the
# only importer is `banking.service.polling` (consumed cross-module via the
# `banking.public` re-export). `source_modules` can NOT be `backend` here: now
# that `providers` exists as a real subpackage, the pair (`backend`,
# `banking.providers`) shares a descendant -> grimp's shared-descendants rule
# rejects it (same workaround as contract:2). We therefore enumerate every
# consumer subtree — all peer modules PLUS banking's own non-`providers`
# internals — so no source subtree overlaps `banking.providers`. The legitimate
# arcs (`service.polling` / `public` -> providers) are whitelisted below; the
# package-level `public -> providers` stays (harmless, unmatched: ignore_imports
# match literal direct edges, and the real edge is `public -> providers.ofx`).
source_modules =
    backend.modules.accounts
    backend.modules.auth
    backend.modules.budget
    backend.modules.debts
    backend.modules.forecasting
    backend.modules.mcp
    backend.modules.notifications
    backend.modules.reconciliation
    backend.modules.savings
    backend.modules.sync
    backend.modules.transactions
    backend.modules.banking.domain
    backend.modules.banking.models
    backend.modules.banking.public
    backend.modules.banking.service
forbidden_modules =
    backend.modules.banking.providers
ignore_imports =
    backend.modules.banking.service.polling -> backend.modules.banking.providers
    backend.modules.banking.public -> backend.modules.banking.providers
    backend.modules.banking.public -> backend.modules.banking.providers.ofx
unmatched_ignore_imports_alerting = none

[importlinter:contract:5]
name = MCP module is consumer-only
type = forbidden
source_modules =
    backend.modules.auth
    backend.modules.accounts
    backend.modules.transactions
    backend.modules.budget
    backend.modules.banking
    backend.modules.reconciliation
    backend.modules.forecasting
    backend.modules.debts
    backend.modules.notifications
    backend.modules.savings
    backend.modules.sync
forbidden_modules =
    backend.modules.mcp

[importlinter:contract:6]
name = Composition-root transports is consumer-only
type = forbidden
# `backend.transports` is the composition root for cross-module HTTP flows (S12.4
# OFX import): it sits ABOVE every module and imports their `.public` surfaces
# freely (like `main.py`), composing flows no single module may own (`commit`
# reads `banking.public` AND writes `transactions.public`, peers forbidden from
# importing each other by contract 1). This contract is the mirror of contract 5
# (`mcp` consumer-only): no `backend.modules.*` and no `backend.shared` may import
# `backend.transports` — the composition root consumes, it is never consumed.
# A NEW contract, NOT an `ignore_imports` (the AC "no new exception" stays true).
# `tests/unit/test_importlinter_coverage.py` asserts every dir under
# `backend/modules/` (+ `backend.shared`) figures in `source_modules` so the
# contract cannot silently stale when a future module is added.
source_modules =
    backend.modules.auth
    backend.modules.accounts
    backend.modules.transactions
    backend.modules.budget
    backend.modules.banking
    backend.modules.reconciliation
    backend.modules.forecasting
    backend.modules.debts
    backend.modules.notifications
    backend.modules.savings
    backend.modules.sync
    backend.modules.mcp
    backend.shared
forbidden_modules =
    backend.transports
