{$APP_DOMAIN:prosperity.localhost} {
	# Security headers
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'"
		-Server
	}

	# TODO: Add rate limiting on /api/auth/* endpoints to prevent brute force attacks
	# Caddy rate_limit plugin is not included in the standard image — requires custom build

	# API routes proxy to Spring Boot
	handle /api/* {
		reverse_proxy api:8080
	}

	# Everything else proxy to SvelteKit
	handle {
		reverse_proxy web:3000
	}
}
